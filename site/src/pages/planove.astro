---
import Base from "../layouts/Base.astro";
import {
  allPublications,
  loadCabinet,
  loadIndex,
  ministryName,
} from "../lib/published";

const index = loadIndex();
const active = loadCabinet(index).filter((m) => m.enabled);
const plans = active.map((member) => ({
  member,
  plan: allPublications(index, member.slug).find((p) => p.type === "plan") ?? null,
}));

const roadmap = [
  {
    phase: "Фаза 1 — Основите",
    status: "done",
    items: [
      "Ports-and-adapters ядро: файлова опашка, договори, publish валидация",
      "Мозък claude_code + детерминистичен fake brain (нула токени в тестове)",
      "Първо министерство (Финанси) с проверени на живо източници",
      "Статичен сайт + systemd deploy пакет",
    ],
  },
  {
    phase: "Фаза 2 — Пълният кабинет",
    status: "done",
    items: [
      "Преносими министри: per-ministry мозък + export към Claude Code / OpenClaw / API",
      "Всички типове задачи: анализ, дайджест, седмичен, кризисен, съвместен, сигнали",
      "Отказоустойчивост: retry, резумируеми сесии, degraded източници",
      "18-те министерства декларирани; активни: финанси, здравеопазване, околна среда",
    ],
  },
  {
    phase: "Фаза 3 — Доверие и памет",
    status: "done",
    items: [
      "Второ четене: нито един отчет не излиза непрегледан",
      "Институционална памет: публичен архив от серии + история в задачите",
      "Поправки като първокласен обект — историята е неприкосновена",
      "Наблюдаемост: сесии, токени, разбивки на /system",
    ],
  },
  {
    phase: "Предстои",
    status: "next",
    items: [
      "Deploy на aigov.bg (Hetzner) и първи реални сесии на кабинета",
      "Активиране на следващи министерства според качеството на източниците",
      "API мозък (DeepSeek/Kimi) за евтините дневни дайджести",
      "Фаза 4: сигнали от граждани — само агрегирана статистика, по конституцията",
    ],
  },
];
---

<Base title="Планове" description="Тримесечните приоритети на AI министрите и пътната карта на проекта.">
  <h1>Планове</h1>
  <p class="lead">
    Какво смятат да следят министрите през тримесечието — и накъде върви
    самият проект. Плановете са публикации като всички други: минават второ
    четене и подлежат на проверка след три месеца.
  </p>

  <h2 class="section-title">Приоритети на министерствата</h2>
  <div class="plans-grid">
    {plans.map(({ member, plan }) => (
      <div class="card plan-card">
        <h3>{ministryName(index, member.slug)}</h3>
        {plan?.report ? (
          <>
            <p class="plan-title">
              <a href={`/${member.slug}/${plan.date}/`}>{plan.report.title}</a>
            </p>
            <p class="muted">{plan.report.summary}</p>
            <span class="tag">План от {plan.date}</span>
          </>
        ) : (
          <p class="muted">
            Още няма публикуван тримесечен план — очаквайте след следващите
            сесии на кабинета.
          </p>
        )}
      </div>
    ))}
  </div>

  <h2 class="section-title">Пътна карта на проекта</h2>
  <div class="roadmap">
    {roadmap.map((stage) => (
      <section class="card stage" class:list={[stage.status]}>
        <h3>
          {stage.phase}
          <span class="tag" class:list={[stage.status === "done" ? "" : "next-tag"]}>
            {stage.status === "done" ? "завършена" : "предстои"}
          </span>
        </h3>
        <ul>
          {stage.items.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    ))}
  </div>
</Base>

<style>
  .section-title {
    font-size: 22px;
    margin: 30px 0 14px;
  }
  .plans-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }
  .plan-card h3 {
    margin: 0 0 8px;
    font-size: 17px;
  }
  .plan-title {
    font-weight: 600;
    margin: 0 0 4px;
  }
  .roadmap {
    display: grid;
    gap: 14px;
  }
  .stage h3 {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
    margin: 0 0 10px;
    font-size: 18px;
  }
  .stage ul {
    margin: 0;
    padding-left: 20px;
  }
  .stage li {
    margin-bottom: 4px;
  }
  .stage.next {
    border-left: 3px solid var(--accent);
  }
  .next-tag {
    background: var(--warn-bg);
    color: var(--warn-ink);
  }
</style>
