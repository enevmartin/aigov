---
import Base from "../layouts/Base.astro";
import {
  allPublications,
  initials,
  loadCabinet,
  loadIndex,
  loadLatest,
  loadTimeseries,
  ministryName,
  type Publication,
} from "../lib/published";

const index = loadIndex();
const cabinet = loadCabinet(index).map((member) => ({
  ...member,
  latest: loadLatest(index, member.slug),
}));
const active = cabinet.filter((m) => m.enabled || m.latest);
const preparing = cabinet.filter((m) => !m.enabled && !m.latest);

// --- key indicators: latest point + delta per active ministry's series ----
interface Kpi {
  ministry: string;
  slug: string;
  metric: string;
  unit: string;
  value: number;
  delta: number | null;
}
const kpis: Kpi[] = [];
for (const member of active) {
  const ts = loadTimeseries(member.slug);
  for (const series of ts?.series ?? []) {
    const points = series.points;
    if (points.length === 0) continue;
    const last = points[points.length - 1]!;
    const prev = points.length > 1 ? points[points.length - 2]! : null;
    kpis.push({
      ministry: member.name,
      slug: member.slug,
      metric: series.name,
      unit: series.unit,
      value: last.value,
      delta: prev ? last.value - prev.value : null,
    });
  }
}
const kpiBand = kpis.slice(0, 8);

// --- active crisis briefs (visible, not sensational) ----------------------
const recentPubs: Publication[] = active.flatMap((m) =>
  allPublications(index, m.slug),
);
const crisisBriefs = recentPubs
  .filter((p) => p.type === "crisis_brief" && p.report)
  .slice(0, 3);

// --- latest reports strip --------------------------------------------------
const latestReports = recentPubs
  .filter((p) => p.report && p.type !== "crisis_brief")
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 6);

const fmtValue = (v: number): string =>
  Number.isInteger(v) ? v.toLocaleString("bg-BG") : v.toLocaleString("bg-BG", { maximumFractionDigits: 2 });
---

<Base title="Състоянието на България днес" banner={true}>
  <h1>Състоянието на България днес</h1>
  <p class="lead">
    Всяко министерство е AI агент, който чете публични данни — статистика,
    новини, отворени данни — и публикува проверени, цитирани анализи на
    български.
  </p>

  {crisisBriefs.length > 0 && (
    <section class="crisis-band" aria-label="Извънредни брифинги">
      {crisisBriefs.map((brief) => (
        <a class="crisis-item" href={`/${brief.slug}/${brief.date}/`}>
          <span class="tag crisis-tag">Извънреден брифинг</span>
          <span class="crisis-title">{brief.report!.title}</span>
          <span class="muted">{ministryName(index, brief.slug)} · {brief.date}</span>
        </a>
      ))}
    </section>
  )}

  {kpiBand.length > 0 && (
    <section aria-label="Ключови индикатори" class="kpi-band">
      {kpiBand.map((kpi) => (
        <a class="kpi card" href={`/${kpi.slug}/`}>
          <span class="kpi-metric">{kpi.metric}</span>
          <span class="kpi-value">
            {fmtValue(kpi.value)}
            <span class="kpi-unit">{kpi.unit}</span>
          </span>
          {kpi.delta !== null && (
            <span
              class="kpi-delta"
              class:list={[kpi.delta > 0 ? "up" : kpi.delta < 0 ? "down" : ""]}
            >
              {kpi.delta > 0 ? "▲" : kpi.delta < 0 ? "▼" : "→"}
              {" "}{fmtValue(Math.abs(kpi.delta))} спрямо предишния период
            </span>
          )}
          <span class="muted kpi-ministry">{kpi.ministry}</span>
        </a>
      ))}
    </section>
  )}

  {latestReports.length > 0 && (
    <section aria-labelledby="latest-title">
      <h2 id="latest-title" class="section-title">Последни отчети</h2>
      <div class="reports-grid">
        {latestReports.map((pub) => (
          <a class="card report-card" href={`/${pub.slug}/${pub.date}/`}>
            <span class="muted report-meta">
              {ministryName(index, pub.slug)} · {pub.date}
            </span>
            <span class="report-title">{pub.report!.title}</span>
            <span class="muted report-summary">{pub.report!.summary}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <h2 class="section-title">Кабинетът</h2>
  {cabinet.length === 0 && (
    <div class="card">
      <p class="muted">Още няма публикувани отчети. Кабинетът заседава скоро.</p>
    </div>
  )}
  <div class="cabinet-grid">
    {active.map((member) => (
      <a class="card minister-card" href={`/${member.slug}/`}>
        <div class="avatar" aria-hidden="true">{initials(member.name)}</div>
        <div class="minister-info">
          <h3>{member.name}</h3>
          {member.persona && (
            <p class="persona muted">AI министър „{member.persona}"</p>
          )}
          {member.latest?.report ? (
            <span class="tag">Отчет от {member.latest.date}</span>
          ) : (
            <span class="tag preparing-tag">активен · очаква първи отчет</span>
          )}
        </div>
      </a>
    ))}
  </div>

  {preparing.length > 0 && (
    <>
      <h2 class="section-title">Подготвят се</h2>
      <p class="muted">
        Декларирани министерства с проверени източници, които още не са
        активирани.
      </p>
      <div class="cabinet-grid">
        {preparing.map((member) => (
          <div class="card minister-card inactive">
            <div class="avatar" aria-hidden="true">{initials(member.name)}</div>
            <div class="minister-info">
              <h3>{member.name}</h3>
              {member.persona && (
                <p class="persona muted">AI министър „{member.persona}"</p>
              )}
              <span class="tag preparing-tag">подготвя се</span>
            </div>
          </div>
        ))}
      </div>
    </>
  )}
</Base>

<style>
  .crisis-band {
    display: grid;
    gap: 10px;
    margin-bottom: 26px;
  }
  .crisis-item {
    display: flex;
    gap: 12px;
    align-items: baseline;
    flex-wrap: wrap;
    text-decoration: none;
    color: inherit;
    background: var(--bad-bg);
    border: 1px solid var(--line);
    border-left: 3px solid var(--bad);
    border-radius: var(--radius);
    padding: 12px 16px;
    font-size: 14.5px;
  }
  .crisis-tag {
    background: transparent;
    color: var(--bad);
    padding: 0;
  }
  .crisis-title {
    font-weight: 600;
  }

  .kpi-band {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px;
    margin-bottom: 36px;
  }
  .kpi {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-decoration: none;
    color: inherit;
    padding: 18px 20px;
  }
  .kpi:hover {
    border-color: var(--accent);
  }
  .kpi-metric {
    font-size: 13.5px;
    color: var(--muted);
  }
  .kpi-value {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.15;
  }
  .kpi-unit {
    font-size: 15px;
    color: var(--muted);
    margin-left: 4px;
  }
  .kpi-delta {
    font-size: 12.5px;
    color: var(--muted);
  }
  .kpi-delta.up {
    color: var(--bad);
  }
  .kpi-delta.down {
    color: var(--accent);
  }
  .kpi-ministry {
    font-size: 12.5px;
    margin-top: 6px;
  }

  .section-title {
    font-size: 22px;
    margin: 34px 0 14px;
  }
  .reports-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }
  .report-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    text-decoration: none;
    color: inherit;
  }
  .report-card:hover {
    border-color: var(--accent);
  }
  .report-meta {
    font-size: 12.5px;
  }
  .report-title {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 17.5px;
    line-height: 1.35;
  }
  .report-summary {
    font-size: 14px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cabinet-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }
  .minister-card {
    display: flex;
    gap: 16px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease;
  }
  a.minister-card:hover {
    border-color: var(--accent);
  }
  .minister-card.inactive {
    opacity: 0.72;
  }
  .avatar {
    flex: 0 0 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--accent-contrast);
    display: grid;
    place-items: center;
    font-weight: 600;
    font-size: 17px;
  }
  .inactive .avatar {
    background: var(--muted);
  }
  .minister-info h3 {
    margin: 0 0 4px;
    font-size: 16.5px;
  }
  .persona {
    margin: 0 0 8px;
    font-size: 13px;
  }
  .preparing-tag {
    background: var(--surface-2);
    color: var(--muted);
  }
</style>
