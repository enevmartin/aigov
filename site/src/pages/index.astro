---
import Base from "../layouts/Base.astro";
import { initials, loadCabinet, loadIndex, loadLatest } from "../lib/published";

const index = loadIndex();
const cabinet = loadCabinet(index).map((member) => ({
  ...member,
  latest: loadLatest(index, member.slug),
}));
const active = cabinet.filter((m) => m.enabled || m.latest);
const preparing = cabinet.filter((m) => !m.enabled && !m.latest);
---

<Base title="Кабинет">
  <h1>Кабинетът</h1>
  <p class="lead">
    Всяко министерство е AI агент, който чете публични данни — статистика,
    новини, отворени данни — и публикува анализи и отчети на български.
  </p>

  {cabinet.length === 0 && (
    <div class="card">
      <p class="muted">Още няма публикувани отчети. Кабинетът заседава скоро.</p>
    </div>
  )}

  <div class="cabinet-grid">
    {active.map((member) => (
      <a class="card minister-card" href={`/${member.slug}/`}>
        <div class="avatar" aria-hidden="true">{initials(member.name)}</div>
        <div class="minister-info">
          <h2>{member.name}</h2>
          {member.persona && (
            <p class="persona muted">AI министър „{member.persona}" · {member.persona_style}</p>
          )}
          {member.latest?.report ? (
            <>
              <p class="report-title">{member.latest.report.title}</p>
              <span class="tag">Отчет от {member.latest.date}</span>
            </>
          ) : (
            <span class="tag preparing-tag">активен · очаква първи отчет</span>
          )}
        </div>
      </a>
    ))}
  </div>

  {preparing.length > 0 && (
    <>
      <h2 class="section-title">Подготвят се</h2>
      <p class="muted">
        Декларирани министерства с проверени източници, които още не са активирани.
      </p>
      <div class="cabinet-grid">
        {preparing.map((member) => (
          <div class="card minister-card inactive">
            <div class="avatar" aria-hidden="true">{initials(member.name)}</div>
            <div class="minister-info">
              <h2>{member.name}</h2>
              {member.persona && (
                <p class="persona muted">AI министър „{member.persona}"</p>
              )}
              <span class="tag preparing-tag">подготвя се</span>
            </div>
          </div>
        ))}
      </div>
    </>
  )}
</Base>

<style>
  .cabinet-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }
  .section-title {
    margin: 40px 0 4px;
  }
  .minister-card {
    display: flex;
    gap: 18px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease;
  }
  a.minister-card:hover {
    border-color: var(--accent);
  }
  .minister-card.inactive {
    opacity: 0.75;
  }
  .avatar {
    flex: 0 0 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    display: grid;
    place-items: center;
    font-weight: 700;
    font-size: 18px;
  }
  .inactive .avatar {
    background: var(--muted);
  }
  .minister-info h2 {
    margin: 0 0 4px;
    font-size: 18px;
  }
  .persona {
    margin: 0 0 8px;
    font-size: 13px;
  }
  .report-title {
    margin: 0 0 8px;
    font-weight: 600;
    font-size: 14px;
  }
  .preparing-tag {
    background: #eee9df;
    color: var(--muted);
  }
</style>
