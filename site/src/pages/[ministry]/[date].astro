---
import Base from "../../layouts/Base.astro";
import DayView from "../../components/DayView.astro";
import { datesFor, loadDay, loadIndex, ministryName } from "../../lib/published";

export function getStaticPaths() {
  const index = loadIndex();
  return Object.keys(index.ministries).flatMap((slug) =>
    datesFor(index, slug).map((date) => ({ params: { ministry: slug, date } })),
  );
}

const { ministry, date } = Astro.params;
const index = loadIndex();
const name = ministryName(index, ministry!);
const day = loadDay(ministry!, date!);
---

<Base title={`${name} — ${date}`}>
  <nav class="crumbs muted">
    <a href="/">Кабинет</a> / <a href={`/${ministry}/`}>{name}</a> / {date}
  </nav>
  <DayView day={day} />
</Base>

<style>
  .crumbs {
    margin-bottom: 18px;
    font-size: 14px;
  }
</style>
