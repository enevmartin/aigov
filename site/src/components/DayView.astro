---
/** One published day of one ministry: report, charts, news, signals. */
import type { PublishedDay } from "../lib/published";

interface Props {
  day: PublishedDay;
  names?: Record<string, string>;
}
const { day, names = {} } = Astro.props;
const chartData = JSON.stringify(day.aggregates?.series ?? []);
const confidenceLabel: Record<string, string> = {
  low: "ниска увереност",
  medium: "средна увереност",
  high: "висока увереност",
};
---

<article>
  <header class="report-header">
    <span class="tag">{day.date}</span>
    {day.report?.confidence && (
      <span class={`tag crisis crisis-${day.report.confidence}`}>
        Извънреден брифинг · {confidenceLabel[day.report.confidence]}
      </span>
    )}
    <h1>{day.report?.title ?? "Публикувани данни"}</h1>
    {day.report && <p class="lead">{day.report.summary}</p>}
    {day.report?.trigger_keywords && (
      <p class="muted trigger-line">
        Задействан от думите: {day.report.trigger_keywords.join(", ")}
      </p>
    )}
    {day.report?.contributors && (
      <p class="muted trigger-line">
        Съвместен доклад по отчети на:{" "}
        {day.report.contributors.map((slug) => names[slug] ?? slug).join(" · ")}
      </p>
    )}
    {day.report?.corrects && (
      <p class="trigger-line">
        <span class="tag corrected">Поправка</span>
        {" "}на публикацията от{" "}
        <a href={`/${day.report.corrects.ministry}/${day.report.corrects.date}/`}>
          {day.report.corrects.date}
        </a>
      </p>
    )}
    {day.correctedBy.length > 0 && (
      <div class="corrected-banner">
        <span class="tag corrected">Поправен</span>
        <span>
          Тази публикация е поправена от:{" "}
          {day.correctedBy.map((c) => (
            <a href={`/${c.ministry}/${c.date}/`}>{c.date}</a>
          ))}
        </span>
      </div>
    )}
  </header>

  {day.aggregates && day.aggregates.series.length > 0 && (
    <section class="charts card">
      <h2>Данните</h2>
      <div class="chart-grid" data-charts={chartData}>
        {day.aggregates.series.map((series, i) => (
          <figure>
            <div class="chart" data-chart-index={i}></div>
            <figcaption class="muted">
              {series.name} ({series.unit}) · източник:
              <a href={series.source.url} rel="noopener">{series.source.title}</a>,
              извлечено {series.source.retrieved}
            </figcaption>
          </figure>
        ))}
      </div>
    </section>
  )}

  {day.reportHtml && <section class="report-body card" set:html={day.reportHtml} />}

  {day.signals && (
    <section class="card">
      <h2>Сигнали от граждани (агрегирано)</h2>
      <p class="muted">
        Само анонимизирана статистика — суровите сигнали никога не се публикуват.
      </p>
      <ul class="signal-list">
        {day.signals.categories.map((c) => (
          <li>
            <span>{c.category}</span>
            <strong>{c.count}</strong>
          </li>
        ))}
      </ul>
      <p>Общо: <strong>{day.signals.total}</strong></p>
      {day.signals.note && <p class="muted">{day.signals.note}</p>}
    </section>
  )}

  {day.news && (
    <section class="news card">
      <h2>Новини на деня</h2>
      <ul class="news-list">
        {day.news.items.map((item) => (
          <li>
            <p class="news-title">{item.title}</p>
            <p class="muted">{item.summary}</p>
            <p class="news-source">
              <a href={item.source.url} rel="noopener">{item.source.title}</a>
              · извлечено {item.source.retrieved}
            </p>
          </li>
        ))}
      </ul>
    </section>
  )}

  {day.report && (
    <section class="sources">
      <h2>Източници на отчета</h2>
      <ul>
        {day.report.sources.map((source) => (
          <li>
            <a href={source.url} rel="noopener">{source.title}</a>
            <span class="muted"> — извлечено {source.retrieved}</span>
          </li>
        ))}
      </ul>
    </section>
  )}
</article>

<script>
  import * as echarts from "echarts";

  interface Series {
    name: string;
    unit: string;
    labels: string[];
    values: number[];
  }

  const grid = document.querySelector<HTMLElement>("[data-charts]");
  if (grid) {
    const series = JSON.parse(grid.dataset.charts ?? "[]") as Series[];
    for (const el of grid.querySelectorAll<HTMLElement>(".chart")) {
      const s = series[Number(el.dataset.chartIndex)];
      if (!s) continue;
      const chart = echarts.init(el);
      chart.setOption({
        color: ["#0f5c46"],
        grid: { left: 48, right: 16, top: 24, bottom: 32 },
        tooltip: { trigger: "axis" },
        xAxis: { type: "category", data: s.labels },
        yAxis: { type: "value", name: s.unit },
        series: [
          {
            name: s.name,
            type: s.labels.length > 1 ? "line" : "bar",
            data: s.values,
            smooth: true,
          },
        ],
      });
      window.addEventListener("resize", () => chart.resize());
    }
  }
</script>

<style>
  .report-header {
    margin-bottom: 24px;
  }
  .report-header h1 {
    margin-top: 10px;
  }
  .tag.crisis {
    margin-left: 8px;
    background: #fbeaea;
    color: #9c2b2b;
  }
  .tag.crisis-high {
    background: #f8d7d7;
  }
  .tag.corrected {
    background: #fdf3d7;
    color: #8a6100;
  }
  .corrected-banner {
    display: flex;
    gap: 10px;
    align-items: baseline;
    margin-top: 10px;
    padding: 10px 14px;
    border: 1px solid #ecdcae;
    border-radius: 8px;
    background: #fdf8e9;
    font-size: 14px;
  }
  .corrected-banner a {
    margin-right: 6px;
  }
  .trigger-line {
    margin: 4px 0 0;
    font-size: 14px;
  }
  section.card {
    margin-bottom: 24px;
  }
  section.card h2 {
    margin-top: 0;
  }
  .chart-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 20px;
  }
  .chart {
    width: 100%;
    height: 280px;
  }
  figure {
    margin: 0;
  }
  figcaption {
    font-size: 13px;
    margin-top: 6px;
  }
  .news-list,
  .signal-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 18px;
  }
  .signal-list {
    gap: 8px;
    margin-bottom: 12px;
  }
  .signal-list li {
    display: flex;
    justify-content: space-between;
    border-bottom: 1px dashed var(--line);
    padding-bottom: 6px;
  }
  .news-title {
    font-weight: 600;
    margin: 0 0 2px;
  }
  .news-list p {
    margin: 0;
  }
  .news-source {
    font-size: 13px;
  }
  .sources h2 {
    font-size: 17px;
  }
  .sources ul {
    padding-left: 20px;
  }
</style>
