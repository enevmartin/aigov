# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ---- uv ----
# uv.lock IS committed (reproducible builds); uv's cache is not.
.uv/

# ---- Secrets ----
.env
.env.*
!.env.example

# ---- Ephemeral data (never committed; keep the dirs via .gitkeep) ----
data/raw/*
!data/raw/.gitkeep
data/staging/*
!data/staging/.gitkeep
# local analytical archive — rebuildable; the PUBLIC archive is
# published/{ministry}/timeseries.json
data/archive.duckdb

# ---- Runtime task queue (ephemeral working state; keep the dirs) ----
tasks/*/*
!tasks/*/.gitkeep

# ---- Generated agent exports (aigov export; derived from ministries/) ----
export/
.claude/agents/

# ---- Node / Astro (site/) ----
node_modules/
site/dist/
site/.astro/
.DS_Store

# ---- Editor / OS ----
.idea/
.vscode/
*.swp
Thumbs.db
