# aigov — environment variables (copy to .env; NEVER commit .env)
#
# The `claude_code` brain shells out to the `claude` CLI, which uses its own
# credentials/session — no API key is required here for the default brain.
#
# The following are only needed by OTHER brains (skeletons for now) or optional
# collectors. Leave blank until the relevant adapter is implemented.

# --- api brain (brains/api) — not implemented yet ---
# DEEPSEEK_API_KEY=
# KIMI_API_KEY=

# --- openclaw brain (brains/openclaw) — not implemented yet ---
# OPENCLAW_GATEWAY=localhost:18789

# --- ingest (optional) ---
# Override the default polite User-Agent used by scrapers/collectors.
# AIGOV_USER_AGENT=aigov.bg data collector (+https://aigov.bg; contact: admin@aigov.bg)
